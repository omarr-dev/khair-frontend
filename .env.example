# API Configuration
# For local development, use:
NEXT_PUBLIC_API_URL=http://localhost:5000

# For production (Railway), use your Railway backend URL:
# NEXT_PUBLIC_API_URL=https://your-backend-app.railway.app

# For staging:
# NEXT_PUBLIC_API_URL=https://your-staging-backend.railway.app

# Sentry DSN is hardcoded in src/sentry.*.config.ts (no env var needed).
# Optional — only needed to upload source maps at build time (better stack traces):
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=javascript-nextjs-4h
# SENTRY_AUTH_TOKEN=your-auth-token
